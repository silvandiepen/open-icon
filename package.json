{
  "name": "open-icon",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/open-icon.umd.cjs",
  "module": "./dist/open-icon.js",
  "exports": {
    ".": {
      "import": {
        "default": "./dist/open-icon.js",
        "types": "./dist/open-icon.d.ts"
      },
      "require": {
        "default": "./dist/open-icon.cjs",
        "types": "./dist/open-icon.d.ts"
      }
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:icons": "rm -rf ./src/components/Icon && sh ./scripts/icons.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@sil/storage": "^0.0.7",
    "bemm": "^1.0.4",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.7",
    "@vitejs/plugin-vue": "^4.5.2",
    "sass": "^1.69.7",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^3.7.0",
    "vue-tsc": "^1.8.25"
  }
}
