{
  "name": "open-icon",
  "version": "0.0.17",
  "type": "module",
  "main": "./lib/open-icon.cjs",
  "module": "./lib/open-icon.js",
  "types": "./lib/open-icon.d.ts",
  "files": [
    "lib/icons/**",
    "lib/open-icon.d.ts",
    "lib/open-icon.js",
    "lib/open-icon.cjs",
    "lib/style.css"
  ],
  "exports": {
    ".": {
      "require": "./lib/open-icon.cjs",
      "import": "./lib/open-icon.js",
      "types": "./lib/open-icon.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "npm run build:icons && npm run build:lib && npm run build:web",
    "build:web": "vue-tsc && vite build",
    "build:lib": "vite build --config vite.config.lib.ts",
    "build:meta": "npm run build:meta:ts && npm run build:meta:generate",
    "build:meta:ts": "tsc -p tsconfig.meta.json",
    "build:meta:generate": " node ./src/meta/meta.js",
    "build:icons": "rm -rf ./src/components/Icon && sh ./scripts/icons.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@sil/storage": "^0.0.7",
    "bemm": "^1.0.4",
    "node-fetch": "^3.3.2",
    "vue": "^3.4.7",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@sil/case": "^0.1.0",
    "@types/node": "^20.11.19",
    "@types/node-fetch": "^2.6.11",
    "@vitejs/plugin-vue": "^5.0.3",
    "@yankeeinlondon/code-builder": "^1.2.1",
    "@yankeeinlondon/link-builder": "^1.2.1",
    "@yankeeinlondon/meta-builder": "^1.4.0",
    "cli-block": "^1.4.2",
    "dot-env": "^0.0.1",
    "dotenv": "^16.4.4",
    "mitt": "^3.0.1",
    "openai": "^4.28.0",
    "sass": "^1.69.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^3.7.0",
    "vite-plugin-md": "^0.22.5",
    "vite-plugin-static-copy": "^1.0.0",
    "vue-tsc": "^1.8.27"
  }
}
