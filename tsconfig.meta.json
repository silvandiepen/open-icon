{
    "compilerOptions": {
        "module": "ESNext",
        "target": "ESNext",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "outDir": "./src/meta",
        "resolveJsonModule": true,
        "baseUrl": ".",
        "paths": {
            "@": [
                "./src/"
            ],
            "@/*": [
                "./src/*"
            ]
        },
    },
    "include": [
        "scripts/**/*"
    ]
}